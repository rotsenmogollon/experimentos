# URL pública de Postiz (cambiar si usas túnel Cloudflare)
POSTIZ_URL=http://localhost:4007

# JWT secret (cambiar a algo random en producción)
POSTIZ_JWT_SECRET=financiera-mi-casa-jwt-secret-change-me-2026

# Credenciales de la app de Meta (Facebook/Instagram)
# Obtenlas en https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# (Opcional) Si usas Instagram Standalone en vez de Facebook Business:
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
